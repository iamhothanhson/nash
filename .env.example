# Execution mode: backtest | demo | live
# Market data: mainnet | testnet
MODE=demo
# Must match Binance Futures → Preferences → Position mode (one value only):
#   hedge | oneway | auto
BINANCE_POSITION_MODE=auto
# Signed API recvWindow ms (max 60000). Raise if you still see -1021 timestamp errors.
# BINANCE_RECV_WINDOW_MS=60000
DATA_SOURCE=mainnet
BINANCE_FAPI_LIVE_HOST=https://fapi.binance.com
BINANCE_FAPI_DEMO_HOST=https://demo-fapi.binance.com

INITIAL_CAPITAL=100
ALLOWED_SYMBOLS=TAOUSDT,RENDERUSDT,FETUSDT

# DEMO MODE CONFIG
BINANCE_TESTNET_API_KEY=
BINANCE_TESTNET_SECRET=

# LIVE MODE CONFIG
BINANCE_API_KEY=
BINANCE_SECRET=

# AI: mock | openai
AI_ENABLED=false
AI_MODE=mock
AI_MIN_CONFIDENCE=0.55

# OpenAI API key
OPENAI_API_KEY=
OPENAI_API_MODEL=gpt-5.4-mini
OPENAI_API_TEMPERATURE=0.0

# Global Parameters
LEVERAGE=10
RISK_PER_TRADE=0.01
MAX_EXECUTION_RISK_PER_TRADE=0.02
MAX_OPEN_POSITIONS=3
MAX_TRADES_PER_DAY=10
MAX_DAILY_LOSS=0.05
MAX_LOSSES_PER_DAY=5
MIN_POSITION_PCT_OF_BALANCE=10
EXPOSURE_MULTIPLIER=1.5
TOTAL_EXPOSURE_MULTIPLIER=5

# Notification
ALERTS_ENABLED=true
TELEGRAM_BOT_TOKEN=8706564874:AAE1FoeSszw2Pjem47LTXSrqUzwWthOtJxA
TELEGRAM_CHAT_ID=-5132511316
ALERTS_MODES=demo,live

# Backtest Configuration
BACKTEST_EXIT_SLIPPAGE_BPS=5
BACKTEST_CLOSE_DELAY_BARS=1
BACKTEST_PARTIAL_FILL_RATIO=1.0
BACKTEST_PARTIAL_FILL_DELAY_BARS=1
BACKTEST_END=2026-05-10

STRATEGY_PLAN_DEBUG=false
ENABLE_TREND_STRATEGY=true
TREND_SETUP_AUCTION_LOG=false
STRATEGY_PLAN_LOG_EMPTY_CANDIDATES=false
PLAN_REJECT_DEBUG=false
ENTRY_AFTER_BARS_DEBUG=false
EXIT_DEBUG=false
STRATEGY_SELECTOR_DEBUG=false
