# Execution mode: backtest | demo | live
MODE=demo
# Position mode: hedge | oneway | auto
BINANCE_POSITION_MODE=oneway
LIVE_CONFIRM=NO
DEBUG=true
# DATA_SOURCE: mainnet | testnet | history
DATA_SOURCE=testnet
HISTORY_AUTO_FETCH=false
INITIAL_CAPITAL=10
ALLOWED_SYMBOLS=TAOUSDT,RENDERUSDT,FETUSDT

BINANCE_FAPI_LIVE_HOST=https://fapi.binance.com
BINANCE_FAPI_DEMO_HOST=https://demo-fapi.binance.com

# DEMO MODE
BINANCE_TESTNET_API_KEY=
BINANCE_TESTNET_SECRET=

# LIVE MODE
BINANCE_API_KEY=
BINANCE_SECRET=

# AI: mock | openai
AI_ENABLED=false
AI_MODE=mock
AI_MIN_CONFIDENCE=0.55

# OpenAI API key
OPENAI_API_KEY=
OPENAI_API_MODEL=gpt-5.4-mini
OPENAI_API_TEMPERATURE=0.0

# Notification
ALERTS_ENABLED=true
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=-
ALERTS_MODES=demo,live,backtest

# Global
LEVERAGE=10
RISK_PER_TRADE=0.03
MAX_EXECUTION_RISK_PER_TRADE=0.075
MAX_OPEN_POSITIONS=3
MAX_TRADES_PER_DAY=10
MAX_DAILY_LOSS=0.1
MAX_LOSSES_PER_DAY=5
MIN_POSITION_PCT_OF_BALANCE=10
EXPOSURE_MULTIPLIER=5
TOTAL_EXPOSURE_MULTIPLIER=10
TARGET_DAILY_ROI=30

# Backtest
BACKTEST_EXIT_SLIPPAGE_BPS=5
BACKTEST_CLOSE_DELAY_BARS=0
BACKTEST_PARTIAL_FILL_RATIO=1.0
BACKTEST_PARTIAL_FILL_DELAY_BARS=1
BACKTEST_END=2026-05-10

# Debug
EXIT_DEBUG=false
EXECUTION_REJECT_DEBUG=false
PLAN_REJECT_DEBUG=false
RISK_SIZING_DEBUG=false
LOSS_FILTER=true